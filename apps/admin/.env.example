# ─── Supabase ────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── App ─────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
VITE_APP_ENV=development

# ─── Image uploads (R2 via apps/web's presign API) ────────────────────────────
# Base URL of apps/web, which hosts /api/r2/presign and /api/r2/delete.
# In production this must be https://mamtaestore.in (and R2_ADMIN_ORIGINS in
# apps/web's env must include https://admin.mamtaestore.in for CORS to pass).
VITE_UPLOAD_API_URL=http://localhost:3000

