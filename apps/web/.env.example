# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Needed server-side by the R2 API routes to verify the caller's role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Cloudflare R2 (server-only — used by app/api/r2/* route handlers) ────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_ACCESS_KEY_SECRET=your-r2-access-key-secret
R2_BUCKET_NAME=your-r2-bucket-name
# Public URL the bucket is served from (custom domain or r2.dev subdomain), no trailing slash
R2_PUBLIC_URL=https://your-bucket-public-url
# Optional override; defaults to https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=
# Comma-separated list of origins allowed to call /api/r2/* (the admin app's origin)
R2_ADMIN_ORIGINS=http://localhost:5173,https://admin.mamtaestore.in,https://mamtaestore.in

# ─── WhatsApp Ordering ────────────────────────────────────────────────────────
# Phone number (with country code, no + or spaces) orders are sent to
NEXT_PUBLIC_WHATSAPP_NUMBER=917001346162

# ─── Site Config ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_TAX_AMOUNT=0
NEXT_PUBLIC_FREE_DELIVERY_THRESHOLD=500
NEXT_PUBLIC_DYNAMIC_HOMEPAGE=true
REVALIDATION_TIME=60

# ─── REMOVED (no longer needed after Supabase migration) ─────────────────────
# API_ENDPOINT=
# NEXT_PUBLIC_API_URL=
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
