# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── WhatsApp Ordering ────────────────────────────────────────────────────────
# Phone number (with country code, no + or spaces) orders are sent to
NEXT_PUBLIC_WHATSAPP_NUMBER=917001346162

# ─── Site Config ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_TAX_AMOUNT=0
NEXT_PUBLIC_FREE_DELIVERY_THRESHOLD=500
NEXT_PUBLIC_DYNAMIC_HOMEPAGE=true
REVALIDATION_TIME=60

