# ─── Supabase (used by migration scripts and Edge Functions) ─────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# WARNING: Never expose this key in frontend code or commit to git
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Cloudflare R2 (used by the r2-migration scripts) ─────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_ACCESS_KEY_SECRET=your-r2-access-key-secret
R2_BUCKET_NAME=your-r2-bucket-name
# Public URL the bucket is served from (custom domain or r2.dev subdomain), no trailing slash
R2_PUBLIC_URL=https://your-bucket-public-url
# Optional override; defaults to https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=

# ─── MongoDB (legacy — only needed if re-running the old Mongo migration) ─────
MONGO_URI=
